---
import Main from "../../../layouts/Main.astro";
import {
  getBibleProviderName,
  getBibleChapter,
  listBibleBooks,
  resolveBibleReference,
  searchBible,
} from "../../../lib/bible/bibleData";
import { listScriptures } from "../../../lib/scriptures";
import { buildChapterVerseScriptureMap } from "../../../lib/scriptureRanges";

export async function getStaticPaths() {
  const books = await listBibleBooks();
  return books.flatMap((book) =>
    Array.from({ length: book.chapterCount }, (_value, index) => ({
      params: {
        book: book.code,
        chapter: String(index + 1),
      },
    }))
  );
}

const query = String(Astro.url.searchParams.get("q") ?? "").trim();
const refQuery = String(Astro.url.searchParams.get("ref") ?? "").trim();
const rawScope = String(Astro.url.searchParams.get("scope") ?? "").trim().toLowerCase();
const selectedScope = rawScope === "ot" || rawScope === "nt" ? rawScope : "all";
const requestedBook = String(Astro.params.book ?? "").trim().toLowerCase();
const requestedChapter = Number.parseInt(String(Astro.params.chapter ?? ""), 10);

let provider = "BSB";
let books: Awaited<ReturnType<typeof listBibleBooks>> = [];
let selectedBookCode = "";
let selectedBookName = "";
let selectedChapter = 1;
let chapterCount = 1;
let chapterVerses: Awaited<ReturnType<typeof getBibleChapter>> = [];
let searchResults: Awaited<ReturnType<typeof searchBible>> = [];
let targetVerse = 0;
let selectedBookIndex = -1;

provider = await getBibleProviderName();
books = await listBibleBooks();

if (books.length > 0) {
  const fallbackBook = books[0]?.code ?? "";
  const candidateBook =
    books.some((book) => book.code === requestedBook) ? requestedBook : fallbackBook;
  const selectedBook = books.find((book) => book.code === candidateBook) ?? books[0];
  selectedBookIndex = books.findIndex((book) => book.code === selectedBook?.code);

  selectedBookCode = selectedBook?.code ?? fallbackBook;
  selectedBookName = selectedBook?.name ?? "";
  chapterCount = selectedBook?.chapterCount ?? 1;

  const candidateChapter = Number.isFinite(requestedChapter) ? requestedChapter : 1;
  selectedChapter = Math.min(Math.max(candidateChapter, 1), Math.max(chapterCount, 1));

  chapterVerses = await getBibleChapter(selectedBookCode, selectedChapter);

  if (refQuery) {
    const resolvedRef = await resolveBibleReference(refQuery);
    if (
      resolvedRef &&
      resolvedRef.bookCode === selectedBookCode &&
      resolvedRef.chapter === selectedChapter &&
      resolvedRef.verse
    ) {
      targetVerse = resolvedRef.verse;
    }
  }
}

if (query) {
  searchResults = await searchBible(
    query,
    250,
    selectedScope === "all" ? undefined : { testament: selectedScope }
  );
}

let previousTarget: { bookCode: string; chapter: number } | null = null;
let nextTarget: { bookCode: string; chapter: number } | null = null;

if (selectedBookCode && books.length > 0 && selectedBookIndex >= 0) {
  if (selectedChapter > 1) {
    previousTarget = { bookCode: selectedBookCode, chapter: selectedChapter - 1 };
  } else if (selectedBookIndex > 0) {
    const previousBook = books[selectedBookIndex - 1];
    if (previousBook) {
      previousTarget = { bookCode: previousBook.code, chapter: previousBook.chapterCount };
    }
  }

  if (selectedChapter < chapterCount) {
    nextTarget = { bookCode: selectedBookCode, chapter: selectedChapter + 1 };
  } else if (selectedBookIndex < books.length - 1) {
    const nextBook = books[selectedBookIndex + 1];
    if (nextBook) {
      nextTarget = { bookCode: nextBook.code, chapter: 1 };
    }
  }
}

const scopeSuffix = selectedScope === "all" ? "" : `?scope=${selectedScope}`;
const previousChapterHref = previousTarget
  ? `/bible/${previousTarget.bookCode}/${previousTarget.chapter}${scopeSuffix}`
  : "";
const nextChapterHref = nextTarget
  ? `/bible/${nextTarget.bookCode}/${nextTarget.chapter}${scopeSuffix}`
  : "";
const chapterFootnotesByVerse = new Map<number, { href: string; referenceCount: number }>();
let chapterFootnoteCount = 0;

if (selectedBookCode && selectedChapter > 0 && chapterVerses.length > 0) {
  const chapterMaxVerse = chapterVerses[chapterVerses.length - 1]?.verse ?? chapterVerses.length;
  const scriptureEntries = listScriptures();
  const verseMatches = buildChapterVerseScriptureMap(
    scriptureEntries,
    selectedBookCode,
    selectedChapter,
    chapterMaxVerse
  );

  verseMatches.forEach((entries, verseNumber) => {
    chapterFootnotesByVerse.set(verseNumber, {
      href: `/scriptures/verse/${selectedBookCode}/${selectedChapter}#verse-${verseNumber}`,
      referenceCount: entries.length,
    });
  });
  chapterFootnoteCount = chapterFootnotesByVerse.size;
}

const bookCatalogJson = JSON.stringify(books);
---

<Main title="Bible Reader">
  <h1>{provider}</h1>
  <section class="reader-tools card-panel">
    <div class="controls">
      <div class="scope-pills" role="group" aria-label="Book scope">
        <button
          type="button"
          class:list={["scope-pill", selectedScope === "all" && "is-active"]}
          data-scope-pill
          data-scope="all"
        >
          ALL
        </button>
        <button
          type="button"
          class:list={["scope-pill", selectedScope === "ot" && "is-active"]}
          data-scope-pill
          data-scope="ot"
        >
          OT
        </button>
        <button
          type="button"
          class:list={["scope-pill", selectedScope === "nt" && "is-active"]}
          data-scope-pill
          data-scope="nt"
        >
          NT
        </button>
      </div>

      <form method="get" action="/bible" class="control-group" data-chapter-form>
        <label for="book">Book</label>
        <select id="book" name="book" data-book-select>
          {books.map((book) => (
            <option value={book.code} selected={book.code === selectedBookCode}>
              {book.name}
            </option>
          ))}
        </select>
        <label for="chapter">Chapter</label>
        <select
          id="chapter"
          name="chapter"
          data-chapter-select
        >
          {Array.from({ length: chapterCount }, (_value, index) => {
            const chapterNumber = index + 1;
            return (
              <option value={chapterNumber} selected={chapterNumber === selectedChapter}>
                {chapterNumber}
              </option>
            );
          })}
        </select>
      </form>

      <form method="get" action="/bible" class="control-group control-group-query">
        <label for="lookup">Jump or search</label>
        <input
          id="lookup"
          type="search"
          name="lookup"
          placeholder="e.g. John 3:16 or in the beginning"
          value={refQuery || query}
          data-lookup-input
        />
        <input type="hidden" name="scope" value={selectedScope} data-scope-input />
        <button type="submit">Go</button>
      </form>
    </div>
  </section>

  <section class="card-panel section-spacer">
    <header class="chapter-header">
      <h2>{selectedBookName} {selectedChapter}</h2>
      <div class="chapter-nav">
        {previousChapterHref ? (
          <a href={previousChapterHref} data-reader-nav>Previous</a>
        ) : (
          <span class="chapter-nav-disabled">Previous</span>
        )}
        {nextChapterHref ? <a href={nextChapterHref} data-reader-nav>Next</a> : <span class="chapter-nav-disabled">Next</span>}
      </div>
    </header>
    {chapterFootnoteCount > 0 ? (
      <div class="chapter-footnotes-controls" data-chapter-footnotes-controls>
        <p class="meta">
          {chapterFootnoteCount} verse{chapterFootnoteCount === 1 ? "" : "s"} with confession references in this chapter
        </p>
      </div>
    ) : null}

    {chapterVerses.length > 0 ? (
      <ol class="verse-list">
        {chapterVerses.map((verse) => {
          const footnote = chapterFootnotesByVerse.get(verse.verse);
          return (
            <li class:list={["verse-item", targetVerse === verse.verse && "is-target"]} id={`verse-${verse.verse}`}>
              <a href={`#verse-${verse.verse}`} class="verse-ref">
                {verse.verse}
              </a>
              <span>{verse.text}</span>
              {footnote ? (
                <span class="verse-footnotes" data-verse-footnotes>
                  <a
                    class="verse-footnote-pill"
                    href={footnote.href}
                    title={`Open ${footnote.referenceCount} confession reference${footnote.referenceCount === 1 ? "" : "s"} for ${selectedBookName} ${selectedChapter}:${verse.verse}`}
                    aria-label={`Open confession references for ${selectedBookName} ${selectedChapter}:${verse.verse}`}
                  >
                    MORE
                  </a>
                </span>
              ) : null}
            </li>
          );
        })}
      </ol>
    ) : (
      <p><em>No verses available for this chapter.</em></p>
    )}

    <div class="chapter-nav chapter-nav-bottom">
      {previousChapterHref ? (
        <a href={previousChapterHref} data-reader-nav>Previous</a>
      ) : (
        <span class="chapter-nav-disabled">Previous</span>
      )}
      {nextChapterHref ? <a href={nextChapterHref} data-reader-nav>Next</a> : <span class="chapter-nav-disabled">Next</span>}
    </div>
  </section>

  {query ? (
    <section class="card-panel section-spacer">
      <h2>Search Results</h2>
      <p class="meta">{searchResults.length} results shown for "{query}"</p>

      {searchResults.length > 0 ? (
        <ul class="search-results">
          {searchResults.map((result) => (
            <li>
              <a
                class="search-result-card"
                href={`/bible/${result.bookCode}/${result.chapter}${scopeSuffix}#verse-${result.verse}`}
              >
                <span class="search-result-reference">{result.reference}</span>
                <span class="search-result-text">{result.text}</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
      <p><em>No verses matched that search.</em></p>
      )}
    </section>
  ) : null}

  <script is:inline define:vars={{ bookCatalogJson }}>
    (() => {
      const bookCatalog = JSON.parse(bookCatalogJson);
      const chapterForm = document.querySelector("[data-chapter-form]");
      const bookSelect = document.querySelector("[data-book-select]");
      const chapterSelect = document.querySelector("[data-chapter-select]");
      const scopePills = Array.from(document.querySelectorAll("[data-scope-pill]"));
      const scopeInputs = Array.from(document.querySelectorAll("[data-scope-input]"));
      const lookupForm = document.querySelector(".control-group-query");
      const readerNavLinks = Array.from(document.querySelectorAll("[data-reader-nav]"));
      const readerScrollStorageKey = "bible-reader-scroll-to-chapter";

      const parseScope = (value) => {
        if (value === "ot" || value === "nt") {
          return value;
        }
        return "all";
      };

      const getActiveScope = () => {
        const params = new URLSearchParams(window.location.search);
        return parseScope(String(params.get("scope") || "").trim().toLowerCase());
      };

      const getScopeSuffix = (scope) => (scope === "all" ? "" : `?scope=${scope}`);

      const buildChapterUrl = (bookCode, chapter, scope) =>
        `/bible/${encodeURIComponent(bookCode)}/${chapter}${getScopeSuffix(scope)}`;

      const requestReaderScroll = () => {
        try {
          window.sessionStorage.setItem(readerScrollStorageKey, "1");
        } catch {
          // ignore
        }
      };

      const syncScopeInputs = (scope) => {
        for (const input of scopeInputs) {
          if (!(input instanceof HTMLInputElement)) {
            continue;
          }
          input.value = scope;
        }
      };

      const setActiveScopePill = (scope) => {
        for (const pill of scopePills) {
          if (!(pill instanceof HTMLElement)) {
            continue;
          }
          const pillScope = String(pill.dataset.scope || "all");
          pill.classList.toggle("is-active", pillScope === scope);
          if (pill instanceof HTMLButtonElement) {
            pill.setAttribute("aria-pressed", pillScope === scope ? "true" : "false");
          }
        }
      };

      const getScopedBooks = (scope) =>
        scope === "all" ? bookCatalog : bookCatalog.filter((book) => book.testament === scope);

      const populateBookOptions = (scope, preferredBookCode) => {
        if (!(bookSelect instanceof HTMLSelectElement)) {
          return "";
        }

        const scopedBooks = getScopedBooks(scope);
        const fallbackBookCode = scopedBooks[0]?.code || "";
        const activeBookCode = scopedBooks.some((book) => book.code === preferredBookCode)
          ? preferredBookCode
          : fallbackBookCode;

        bookSelect.innerHTML = "";
        for (const book of scopedBooks) {
          const option = document.createElement("option");
          option.value = book.code;
          option.textContent = book.name;
          option.selected = book.code === activeBookCode;
          bookSelect.append(option);
        }

        return activeBookCode;
      };

      const populateChapterOptions = (bookCode, preferredChapter) => {
        if (!(chapterSelect instanceof HTMLSelectElement)) {
          return 1;
        }

        const selectedBook = bookCatalog.find((book) => book.code === bookCode);
        const maxChapter = selectedBook?.chapterCount || 1;
        const safeChapter = Math.min(Math.max(preferredChapter, 1), maxChapter);

        chapterSelect.innerHTML = "";
        for (let chapterNumber = 1; chapterNumber <= maxChapter; chapterNumber += 1) {
          const option = document.createElement("option");
          option.value = String(chapterNumber);
          option.textContent = String(chapterNumber);
          option.selected = chapterNumber === safeChapter;
          chapterSelect.append(option);
        }

        return safeChapter;
      };

      let activeScope = getActiveScope();
      setActiveScopePill(activeScope);
      syncScopeInputs(activeScope);

      if (
        chapterForm instanceof HTMLFormElement &&
        bookSelect instanceof HTMLSelectElement &&
        chapterSelect instanceof HTMLSelectElement
      ) {
        const initialBookCode = String(bookSelect.value || "");
        const initialChapterValue = Number.parseInt(String(chapterSelect.value || "1"), 10);
        const selectedBookCode = populateBookOptions(activeScope, initialBookCode);
        populateChapterOptions(
          selectedBookCode,
          Number.isFinite(initialChapterValue) && initialChapterValue > 0 ? initialChapterValue : 1
        );

        bookSelect.addEventListener("change", () => {
          const nextBookCode = String(bookSelect.value || "");
          if (!nextBookCode) {
            return;
          }
          populateChapterOptions(nextBookCode, 1);
          requestReaderScroll();
          window.location.assign(buildChapterUrl(nextBookCode, 1, activeScope));
        });

        chapterSelect.addEventListener("change", () => {
          const nextBookCode = String(bookSelect.value || "");
          if (!nextBookCode) {
            return;
          }
          const nextChapter = Number.parseInt(String(chapterSelect.value || "1"), 10);
          const safeChapter = Number.isFinite(nextChapter) && nextChapter > 0 ? nextChapter : 1;
          requestReaderScroll();
          window.location.assign(buildChapterUrl(nextBookCode, safeChapter, activeScope));
        });
      }

      for (const pill of scopePills) {
        if (!(pill instanceof HTMLButtonElement)) {
          continue;
        }
        pill.addEventListener("click", () => {
          const nextScope = parseScope(String(pill.dataset.scope || "all"));
          if (nextScope === activeScope) {
            return;
          }
          activeScope = nextScope;
          setActiveScopePill(activeScope);
          syncScopeInputs(activeScope);

          if (
            chapterForm instanceof HTMLFormElement &&
            bookSelect instanceof HTMLSelectElement &&
            chapterSelect instanceof HTMLSelectElement
          ) {
            const currentBookCode = String(bookSelect.value || "");
            const scopedBookCode = populateBookOptions(activeScope, currentBookCode);
            if (!scopedBookCode) {
              return;
            }
            populateChapterOptions(scopedBookCode, 1);
            requestReaderScroll();
            window.location.assign(buildChapterUrl(scopedBookCode, 1, activeScope));
          }
        });
      }

      if (lookupForm instanceof HTMLFormElement) {
        lookupForm.addEventListener("submit", requestReaderScroll);
      }

      for (const link of readerNavLinks) {
        if (!(link instanceof HTMLAnchorElement)) {
          continue;
        }
        link.addEventListener("click", requestReaderScroll);
      }

      const parseVerseTarget = () => {
        const params = new URLSearchParams(window.location.search);
        const refValue = String(params.get("ref") || "").trim();
        if (refValue) {
          const normalized = refValue
            .toLowerCase()
            .replace(/\./g, "")
            .replace(/\u2013|\u2014/g, "-")
            .replace(/\s+/g, " ")
            .trim();
          const match = normalized.match(/^(.+?)\s+(\d+)(?::(\d+(?:-\d+)?))?$/);
          if (match) {
            const chapterFromRef = Number.parseInt(String(match[2] || ""), 10);
            const versePart = String(match[3] || "");
            const verseFromRef = versePart ? Number.parseInt(versePart.split("-")[0] || "", 10) : NaN;
            if (Number.isFinite(verseFromRef) && verseFromRef > 0) {
              return { verse: verseFromRef, source: "ref" };
            }
            const pathParts = window.location.pathname.split("/").filter(Boolean);
            const currentChapter = Number.parseInt(pathParts[pathParts.length - 1] || "", 10);
            if (Number.isFinite(chapterFromRef) && Number.isFinite(currentChapter) && currentChapter === 1) {
              return { verse: chapterFromRef, source: "ref" };
            }
          }
        }

        const hashMatch = window.location.hash.match(/^#verse-(\d+)$/);
        if (hashMatch) {
          const hashVerse = Number.parseInt(hashMatch[1] || "", 10);
          if (Number.isFinite(hashVerse) && hashVerse > 0) {
            return { verse: hashVerse, source: "hash" };
          }
        }

        return { verse: NaN, source: "none" };
      };

      const highlightVerse = (verseNumber, shouldScroll = true) => {
        if (!Number.isFinite(verseNumber) || verseNumber < 1) {
          return;
        }

        const target = document.getElementById(`verse-${verseNumber}`);
        if (!(target instanceof HTMLElement)) {
          return;
        }

        target.classList.add("is-target", "is-target-flash");

        const header = document.querySelector(".top");
        const headerBottom = header instanceof HTMLElement ? header.getBoundingClientRect().bottom : 0;
        const targetTop = window.scrollY + target.getBoundingClientRect().top - headerBottom - 12;

        const rect = target.getBoundingClientRect();
        const absoluteTop = window.scrollY + rect.top;
        const absoluteBottom = window.scrollY + rect.bottom;
        const visibleTop = window.scrollY + headerBottom + 8;
        const visibleBottom = window.scrollY + window.innerHeight - 16;
        const isVisible = absoluteTop >= visibleTop && absoluteBottom <= visibleBottom;

        if (shouldScroll && !isVisible) {
          window.scrollTo({
            top: Math.max(targetTop, 0),
            behavior: "smooth",
          });
        }

        window.setTimeout(() => {
          target.classList.remove("is-target-flash");
        }, 1400);
      };

      const scrollChapterHeaderIntoView = () => {
        const chapterHeader = document.querySelector(".chapter-header");
        if (!(chapterHeader instanceof HTMLElement)) {
          return;
        }
        const header = document.querySelector(".top");
        const headerBottom = header instanceof HTMLElement ? header.getBoundingClientRect().bottom : 0;
        const chapterTop = window.scrollY + chapterHeader.getBoundingClientRect().top - headerBottom - 12;
        window.scrollTo({
          top: Math.max(chapterTop, 0),
          behavior: "auto",
        });
      };

      const settleChapterHeaderIntoView = () => {
        window.requestAnimationFrame(scrollChapterHeaderIntoView);
        window.setTimeout(scrollChapterHeaderIntoView, 80);
        window.setTimeout(scrollChapterHeaderIntoView, 220);
      };

      const shouldScrollToChapter = () => {
        try {
          const shouldScroll = window.sessionStorage.getItem(readerScrollStorageKey) === "1";
          window.sessionStorage.removeItem(readerScrollStorageKey);
          return shouldScroll;
        } catch {
          return false;
        }
      };

      const verseTarget = parseVerseTarget();
      if (verseTarget.source === "ref") {
        if (/^#verse-\d+$/.test(window.location.hash)) {
          window.history.replaceState({}, "", `${window.location.pathname}${window.location.search}`);
          settleChapterHeaderIntoView();
        }
        highlightVerse(verseTarget.verse, false);
      } else {
        highlightVerse(verseTarget.verse, verseTarget.source === "hash");
      }

      if (verseTarget.source === "none" && shouldScrollToChapter()) {
        settleChapterHeaderIntoView();
      }
    })();
  </script>
</Main>

<style>
  .section-spacer {
    margin-top: 1rem;
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.55rem 1rem;
    margin-top: 0;
  }

  .reader-tools {
    padding: 0.7rem 0.85rem;
  }

  .scope-pills {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-self: center;
    margin-top: -0.12rem;
  }

  .scope-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.1rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--surface-border);
    background: var(--surface-bg-muted);
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
  }

  .scope-pill:hover,
  .scope-pill:focus-visible {
    border-color: var(--surface-border-strong);
    background: var(--surface-bg-hover);
    outline: none;
  }

  .scope-pill.is-active {
    border-color: var(--color-link);
    background: color-mix(in srgb, var(--color-link) 14%, var(--surface-bg));
  }

  .control-group {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    flex-wrap: wrap;
    margin: 0;
  }

  .control-group label {
    font-weight: 600;
  }

  .control-group select {
    min-width: 7rem;
  }

  .control-group-query {
    flex: 1 1 26rem;
  }

  .control-group-query input[type="search"] {
    flex: 1 1 18rem;
    min-width: 16rem;
  }

  .chapter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .chapter-header h2 {
    margin: 0;
  }

  .chapter-footnotes-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.55rem;
  }

  .chapter-footnotes-controls p {
    margin: 0;
  }

  .chapter-nav {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }

  .chapter-nav a,
  .chapter-nav-disabled {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 6.2rem;
    padding: 0.42rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--surface-border);
    background: var(--surface-bg-muted);
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
  }

  .chapter-nav a:hover,
  .chapter-nav a:focus-visible {
    border-color: var(--color-link);
    background: var(--surface-bg);
  }

  .chapter-nav-disabled {
    opacity: 0.58;
  }

  .chapter-nav-bottom {
    margin-top: 0.8rem;
  }

  .verse-list {
    margin: 0.9rem 0 0;
    padding-left: 0;
    list-style: none;
    display: grid;
    gap: 0.1rem;
  }

  .verse-item {
    padding: 0.1rem 0.45rem;
    line-height: 1.22;
    border-radius: 8px;
    scroll-margin-top: 6.5rem;
  }

  .verse-item.is-target {
    background: rgba(255, 232, 107, 0.72);
    border: 1px solid rgba(232, 179, 35, 0.58);
    box-shadow: 0 0 0 2px rgba(232, 179, 35, 0.26);
  }

  .verse-item:target {
    background: rgba(255, 232, 107, 0.72);
    border: 1px solid rgba(232, 179, 35, 0.58);
    box-shadow: 0 0 0 2px rgba(232, 179, 35, 0.26);
  }

  .verse-item.is-target-flash {
    animation: verse-target-pulse 1.2s ease-out 1;
  }

  @keyframes verse-target-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(232, 179, 35, 0.6);
    }
    100% {
      box-shadow: 0 0 0 10px rgba(232, 179, 35, 0);
    }
  }

  .verse-ref {
    display: inline-block;
    min-width: 1.6rem;
    font-weight: 700;
    margin-right: 0.45rem;
  }

  .verse-footnotes {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-left: 0.45rem;
    vertical-align: text-top;
  }

  .verse-footnote-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.2rem;
    padding: 0.06rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--surface-border-strong);
    background: var(--surface-bg-strong);
