---
import Main from "../layouts/Main.astro";
---

<Main title="Page Not Found">
  <section class="not-found card-panel">
    <p class="status">404</p>
    <h1>This page was not found.</h1>
    <p class="lead">
      The link may be outdated, misspelled, or moved. You can continue from one of these pages:
    </p>
    <nav class="actions" aria-label="404 quick links">
      <a href="/">Home</a>
      <a href="/confessions">Confessions</a>
      <a href="/scriptures">Scriptures</a>
      <a href="/bible/gen/1">Bible Reader</a>
    </nav>
    <p class="path">
      Requested path: <code id="requested-path">unknown</code>
    </p>
  </section>

  <script is:inline>
    (() => {
      const el = document.getElementById("requested-path");
      if (!el || typeof window === "undefined") {
        return;
      }
      const value = window.location.pathname + window.location.search + window.location.hash;
      el.textContent = value || "/";
    })();
  </script>

  <style>
    .not-found {
      margin: 2rem auto;
      max-width: 760px;
      padding: 1.5rem 1.5rem 1.35rem;
      border-color: var(--surface-border-strong);
      background:
        linear-gradient(180deg, var(--surface-bg-muted), transparent 42%),
        var(--card-bg);
    }

    .status {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin: 0;
      padding: 0.08rem 0.65rem;
      border-radius: 999px;
      border: 1px solid var(--surface-border-strong);
      background: var(--surface-bg-strong);
      color: var(--color-heading);
      font-weight: 700;
      letter-spacing: 0.06em;
      font-size: 0.9rem;
    }

    h1 {
      margin-top: 0.7rem;
      margin-bottom: 0.6rem;
      font-size: clamp(2rem, 4.8vw, 3rem);
    }

    .lead {
      margin: 0;
      color: var(--color-muted);
      max-width: 62ch;
    }

    .actions {
      margin-top: 1.05rem;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem;
    }

    .actions a {
      border: 1px solid var(--surface-border);
      border-radius: 10px;
      padding: 0.58rem 0.75rem;
      text-decoration: none;
      color: var(--color-link);
      background: var(--surface-bg-muted);
      font-weight: 600;
      text-align: center;
      transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }

    .actions a:hover,
    .actions a:focus-visible {
      border-color: var(--surface-border-strong);
      background: var(--surface-bg-hover);
      transform: translateY(-1px);
      text-decoration: none;
      outline: none;
    }

    .path {
      margin-top: 1rem;
      color: var(--color-muted);
      font-size: 0.95rem;
    }

    .path code {
      color: var(--color-heading);
      background: var(--surface-bg-muted);
      border: 1px solid var(--surface-border);
      border-radius: 8px;
      padding: 0.1rem 0.35rem;
      word-break: break-all;
    }

    @media (max-width: 620px) {
      .not-found {
        margin-top: 1.2rem;
        padding: 1.15rem 1rem 1rem;
      }

      .actions {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Main>
