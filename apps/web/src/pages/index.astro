---
import Main from "../layouts/Main.astro";
import { listConfessions, getUpdatedAt } from "../lib/confessions";

const confessions = listConfessions();
const updatedAt = getUpdatedAt();
---

<Main title="Confessions Hub">
  <h1>Reformed Confessions & Bible Hub</h1>
  <p>Browse confessions, inspect every cited scripture, and read/search the full Bible text.</p>

  <section class="card-panel">
    <h2>Confessions</h2>
    <ul class="confession-list">
      {confessions.map((item) => (
        <li data-confession={item.slug}>
          <a class="confession-link confession-item-link" href={`/confessions/${item.slug}`}>
            <span class="confession-badge">{item.shortCode}</span>
            <span>{item.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="card-panel section-spacer">
    <h2>Scripture Tools</h2>
    <ul class="tool-list">
      <li data-tool="references">
        <a class="tool-item-link" href="/scriptures">
          <span>Scripture References</span>
        </a>
      </li>
      <li data-tool="bible">
        <a class="tool-item-link" href="/bible/gen/1">
          <span>Read the Bible</span>
        </a>
      </li>
    </ul>
  </section>
</Main>

<style>
  .section-spacer {
    margin-top: 1rem;
  }

  .confession-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .confession-list li,
  .tool-list li {
    list-style: none;
  }

  .confession-item-link,
  .tool-item-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid var(--surface-border);
    border-left-width: 4px;
    border-left-color: var(--confession-accent-border, var(--surface-border-strong));
    border-radius: 10px;
    background: var(--surface-bg-muted);
    padding: 0.45rem 0.55rem;
    text-decoration: none;
  }

  .confession-item-link:hover,
  .confession-item-link:focus-visible,
  .tool-item-link:hover,
  .tool-item-link:focus-visible {
    border-color: var(--confession-accent-border, var(--card-hover-border));
    text-decoration: none;
  }

  .tool-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .tool-item-link {
    border-left-color: var(--tool-accent-border);
    color: var(--tool-accent-text);
    font-weight: 600;
  }

  .tool-item-link:hover,
  .tool-item-link:focus-visible {
    border-color: var(--tool-accent-border);
    color: var(--tool-accent-text);
  }

  [data-tool="references"] {
    --tool-accent-border: rgba(168, 174, 181, 0.56);
    --tool-accent-bg: rgba(168, 174, 181, 0.16);
    --tool-accent-text: #d9dee4;
  }

  [data-tool="bible"] {
    --tool-accent-border: rgba(78, 88, 98, 0.68);
    --tool-accent-bg: rgba(78, 88, 98, 0.28);
    --tool-accent-text: #eef1f4;
  }

  :global([data-theme="light"]) [data-tool="references"] {
    --tool-accent-border: rgba(104, 113, 122, 0.58);
    --tool-accent-bg: rgba(188, 194, 201, 0.5);
    --tool-accent-text: #1f2429;
  }

  :global([data-theme="light"]) [data-tool="bible"] {
    --tool-accent-border: rgba(50, 57, 64, 0.64);
    --tool-accent-bg: rgba(86, 96, 106, 0.28);
    --tool-accent-text: #11161a;
  }

  :global([data-theme="light"]) .tool-item-link,
  :global([data-theme="light"]) .tool-item-link:hover,
  :global([data-theme="light"]) .tool-item-link:focus-visible {
    color: var(--tool-accent-text);
  }

  @media (max-width: 720px) {
    .confession-list,
    .tool-list {
      grid-template-columns: 1fr;
    }
  }
</style>
