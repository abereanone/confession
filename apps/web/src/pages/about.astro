---
import Main from "../layouts/Main.astro";
---

<Main title="About | Confessions Hub">
  <section class="about card-panel">
    <h1>About Confessions Hub</h1>
    <p>
      Confessions Hub is a searchable reading site for historic Christian confessions and their Scripture
      references.
    </p>
    <p>
      It is built to let you move quickly between confession text, reference indexes, and full Bible
      chapters in one place.
    </p>
    <ul>
      <li>Browse confessions by document and chapter/article.</li>
      <li>Search Scripture references used across confessions.</li>
      <li>Read and search full Bible text by book, chapter, verse, or phrase.</li>
    </ul>
  </section>
</Main>

<style>
  .about {
    margin-top: 1rem;
    max-width: 860px;
  }

  .about p {
    margin: 0.65rem 0;
  }

  .about ul {
    margin: 0.75rem 0 0;
    padding-left: 1.2rem;
  }
</style>
