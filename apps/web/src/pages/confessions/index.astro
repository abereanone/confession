---
import Main from "../../layouts/Main.astro";
import { listConfessions } from "../../lib/confessions";

const confessions = listConfessions();
---

<Main title="Confessions">
  <h1>Confessions</h1>
  <p>Choose a confession to browse by chapter/article.</p>

  <ul id="confession-list">
    {confessions.map((item) => (
      <li data-confession={item.slug}>
        <a class="confession-link" href={`/confessions/${item.slug}`}>
          <span class="confession-badge">{item.shortCode}</span>
          <span>{item.title}</span>
        </a>
      </li>
    ))}
  </ul>
</Main>

<style>
  #confession-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: 0.5rem 1rem;
    padding: 0;
  }

  #confession-list li {
    list-style: none;
  }

  #confession-list li a {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    height: 100%;
    padding: 0.5rem 0.6rem;
    border-radius: 10px;
    border: 1px solid var(--card-border);
    border-left-width: 4px;
    border-left-color: var(--confession-accent-border, var(--surface-border-strong));
    background: var(--card-bg);
    text-decoration: none;
  }

  #confession-list li a:hover,
  #confession-list li a:focus-visible {
    border-color: var(--confession-accent-border, var(--card-hover-border));
    text-decoration: none;
  }
</style>
