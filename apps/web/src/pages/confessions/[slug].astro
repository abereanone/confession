---
import Main from "../../layouts/Main.astro";
import BibleReferencesScript from "../../components/BibleReferencesScript.astro";
import ConfessionReferenceHighlightScript from "../../components/ConfessionReferenceHighlightScript.astro";
import {
  findConfession,
  getConfessionDisplayUnits,
  listConfessions,
} from "../../lib/confessions";
import { autoLinkBibleRefs } from "../../lib/bible/autoLinkBibleRefs";
import { normalizeReference } from "../../lib/bible/normalizeRef";
import { getVerseLookup } from "../../lib/bible/bibleData";

export function getStaticPaths() {
  return listConfessions().map((item) => ({
    params: { slug: item.slug },
  }));
}

const { slug } = Astro.params;
const confession = findConfession(String(slug));

if (!confession) {
  return Astro.redirect("/confessions");
}

const unitId = (number: number) => `unit-${number}`;
const paragraphId = (unitNumber: number, paragraphNumber: number) =>
  `para-${unitNumber}-${paragraphNumber}`;
const displayUnits = getConfessionDisplayUnits(confession);
const showParagraphMeta = confession.slug !== "belgic-confession";
const proofTagPattern = /\{\{proofs:\s*([^}]+?)\s*\}\}/gi;

function hasProofTags(value: string): boolean {
  return /\{\{proofs:\s*[^}]+?\s*\}\}/i.test(value);
}

function renderParagraphFromProofTags(value: string, readerModeEnabled: boolean): string {
  const source = String(value ?? "");
  if (readerModeEnabled) {
    return source
      .replace(proofTagPattern, "")
      .replace(/\s{2,}/g, " ")
      .replace(/\s+([,.;:!?])/g, "$1")
      .trim();
  }

  return source.replace(proofTagPattern, "($1)");
}

const references = new Set<string>();
for (const unit of displayUnits) {
  for (const paragraph of unit.content) {
    const linkedParagraph = autoLinkBibleRefs(renderParagraphFromProofTags(paragraph, false));
    const matches = [...linkedParagraph.matchAll(/data-ref="([^"]+)"/g)];
    matches.forEach((match) => {
      const reference = normalizeReference(String(match[1] ?? "").trim());
      if (reference) {
        references.add(reference);
      }
    });
  }
}

const verseLookup = await getVerseLookup([...references]);
---

<Main title={confession.title}>
  <div class="confession-page" id="confession-top" data-confession={confession.slug}>
    <section class="confession-header">
      <h1>
        <span class="confession-badge">{confession.shortCode}</span>
        <span>{confession.title}</span>
      </h1>
      <p class="confession-meta-line">
        <a class="confession-link" href={`/confessions/${confession.slug}/about`}>About this confession</a>
      </p>
    </section>

    <section class="tools">
      <div class="tool-control">
        <label for="unit-select">Jump to chapter</label>
        <select id="unit-select">
          <option value="">Select a chapter</option>
          {displayUnits.map((unit) => (
            <option value={unitId(unit.number)}>
              {confession.unitLabel} {unit.number}: {unit.title}
            </option>
          ))}
        </select>
      </div>
      <div class="tool-control">
        <label for="unit-filter">Filter paragraphs</label>
        <input
          id="unit-filter"
          type="search"
          placeholder="Search confession paragraph text - Use quotes for exact phrase like &quot;the church&quot;"
          autocomplete="off"
        />
      </div>
      <p id="unit-results-meta" class="meta">{displayUnits.length} total</p>
    </section>

    <p id="unit-no-results" hidden>No paragraphs matched that filter.</p>

    {displayUnits.map((unit) => (
      <section class="unit" id={unitId(unit.number)}>
        <h2 class="unit-title">{confession.unitLabel} {unit.number}: {unit.title}</h2>
        <div class="paragraph-list">
          {unit.content.map((paragraph, index) => (
            <article
              class="paragraph-card card-panel"
              id={paragraphId(unit.number, index + 1)}
              data-bible-autolink
              data-paragraph-card
              data-proof-source={hasProofTags(paragraph) ? paragraph : undefined}
            >
              {showParagraphMeta ? (
                <p class="paragraph-meta">{confession.unitLabel} {unit.number} - Paragraph {index + 1}</p>
              ) : null}
              <p>{renderParagraphFromProofTags(paragraph, false)}</p>
            </article>
          ))}
        </div>
        <p class="unit-back-to-top">
          <a href="#confession-top">Back to top</a>
        </p>
      </section>
    ))}
  </div>
</Main>

<BibleReferencesScript verseLookup={verseLookup} />
<ConfessionReferenceHighlightScript />

<script>
  const confessionPage = document.querySelector(".confession-page");
  const root = document.documentElement;
  const input = document.getElementById("unit-filter");
  const unitSelect = document.getElementById("unit-select");
  const meta = document.getElementById("unit-results-meta");
  const noResults = document.getElementById("unit-no-results");
  const units = Array.from(document.querySelectorAll(".unit"));
  const paragraphCards = Array.from(document.querySelectorAll("[data-paragraph-card]"));

  const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

  const getParagraphBodies = () =>
    Array.from(document.querySelectorAll(".paragraph-card p:last-child"));

  const parseSearchTerms = (rawQuery) => {
    const terms = [];
    const query = String(rawQuery ?? "");
    const phraseRegex = /"([^"]+)"/g;
    let remaining = query;

    for (const match of query.matchAll(phraseRegex)) {
      const phrase = String(match[1] ?? "").trim();
      if (phrase) {
        terms.push(phrase);
      }
      remaining = remaining.replace(String(match[0] ?? ""), " ");
    }

    remaining
      .trim()
      .split(/\s+/)
      .map((token) => token.trim())
      .filter(Boolean)
      .forEach((token) => terms.push(token));

    return [...new Set(terms.map((term) => term.toLowerCase()))];
  };

  const clearHighlights = (root) => {
    const marks = Array.from(root.querySelectorAll("mark.search-hit"));
    marks.forEach((mark) => {
      const parent = mark.parentNode;
      if (!parent) {
        return;
      }
      parent.replaceChild(document.createTextNode(mark.textContent || ""), mark);
      parent.normalize();
    });
  };

  const highlightInNode = (node, regex) => {
    const text = node.nodeValue || "";
    const matches = Array.from(text.matchAll(regex));
    if (matches.length === 0) {
      return;
    }

    const fragment = document.createDocumentFragment();
    let cursor = 0;

    matches.forEach((match) => {
      const index = match.index ?? 0;
      const hit = match[0] ?? "";
      if (!hit) {
        return;
      }

      if (index > cursor) {
        fragment.appendChild(document.createTextNode(text.slice(cursor, index)));
      }

      const mark = document.createElement("mark");
      mark.className = "search-hit";
      mark.textContent = hit;
      fragment.appendChild(mark);
      cursor = index + hit.length;
    });

    if (cursor < text.length) {
      fragment.appendChild(document.createTextNode(text.slice(cursor)));
    }

    node.parentNode?.replaceChild(fragment, node);
  };

  const highlightMatches = (rawQuery) => {
    const paragraphBodies = getParagraphBodies();
    paragraphBodies.forEach((paragraph) => {
      if (!(paragraph instanceof HTMLElement)) {
        return;
      }

      clearHighlights(paragraph);
    });

    const terms = parseSearchTerms(rawQuery);

    if (terms.length === 0) {
      return;
    }

    const pattern = terms
      .map((term) => escapeRegExp(term))
      .sort((a, b) => b.length - a.length)
      .join("|");

    if (!pattern) {
      return;
    }

    const regex = new RegExp(pattern, "gi");

    paragraphBodies.forEach((paragraph) => {
      if (!(paragraph instanceof HTMLElement)) {
        return;
      }

      const walker = document.createTreeWalker(paragraph, NodeFilter.SHOW_TEXT, {
        acceptNode: (node) => {
          const value = node.nodeValue || "";
          if (!value.trim()) {
            return NodeFilter.FILTER_REJECT;
          }

          const parent = node.parentElement;
          if (!parent || parent.closest("mark.search-hit")) {
            return NodeFilter.FILTER_REJECT;
          }

          regex.lastIndex = 0;
          return regex.test(value) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
        },
      });

      const textNodes = [];
      while (walker.nextNode()) {
        textNodes.push(walker.currentNode);
      }

      textNodes.forEach((node) => {
        regex.lastIndex = 0;
        highlightInNode(node, regex);
      });
    });
  };

  const renderParagraphFromProofTagsClient = (source, enabled) => {
    const raw = String(source ?? "");
    if (enabled) {
      return raw
        .replace(/\{\{proofs:\s*([^}]+?)\s*\}\}/gi, "")
        .replace(/\s{2,}/g, " ")
        .replace(/\s+([,.;:!?])/g, "$1")
        .trim();
    }
    return raw.replace(/\{\{proofs:\s*([^}]+?)\s*\}\}/gi, "($1)");
  };

  const applyReaderModeToTaggedParagraphs = (enabled) => {
    const taggedCards = Array.from(document.querySelectorAll("[data-proof-source]"));
    taggedCards.forEach((card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      const source = card.dataset.proofSource;
      if (!source) {
        return;
      }

      const paragraph = card.querySelector("p:last-child");
      if (!(paragraph instanceof HTMLElement)) {
        return;
      }

      paragraph.textContent = renderParagraphFromProofTagsClient(source, enabled);
      card.dataset.bibleProcessed = "false";
    });

    document.dispatchEvent(new Event("astro:page-load"));
    if (input instanceof HTMLInputElement) {
      window.setTimeout(() => highlightMatches(input.value), 0);
    }
  };

  const setReaderMode = (enabled) => {
    if (!(confessionPage instanceof HTMLElement)) {
      return;
    }

    applyReaderModeToTaggedParagraphs(enabled);
    confessionPage.classList.toggle("reader-mode-enabled", enabled);
  };

  const applyFromGlobalMode = (mode) => {
    setReaderMode(mode === "read");
    if (input instanceof HTMLInputElement) {
      input.dispatchEvent(new Event("input", { bubbles: true }));
    }
  };

  applyFromGlobalMode(root.dataset.readerMode || "study");
  document.addEventListener("site:reader-mode-change", (event) => {
    const mode = event instanceof CustomEvent ? String(event.detail?.mode || "study") : "study";
    applyFromGlobalMode(mode);
  });

  const scrollToConfessionTop = () => {
    if (!(confessionPage instanceof HTMLElement)) {
      return;
    }

    const header = document.querySelector(".top");
    const headerHeight = header instanceof HTMLElement ? header.getBoundingClientRect().height : 0;
    const targetTop = window.scrollY + confessionPage.getBoundingClientRect().top - headerHeight - 12;

    window.scrollTo({
      top: Math.max(targetTop, 0),
      behavior: "smooth",
    });
  };

  document.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target : null;
    const topLink = target?.closest('a[href="#confession-top"]');
    if (!(topLink instanceof HTMLAnchorElement)) {
      return;
    }

    event.preventDefault();
    scrollToConfessionTop();
    if (window.location.hash !== "#confession-top") {
      window.history.replaceState(null, "", "#confession-top");
    }
  });

  if (unitSelect instanceof HTMLSelectElement) {
    unitSelect.addEventListener("change", () => {
      const targetId = unitSelect.value;
      if (!targetId) {
        return;
      }

      if (input instanceof HTMLInputElement && input.value) {
        input.value = "";
        input.dispatchEvent(new Event("input", { bubbles: true }));
      }

      const target = document.getElementById(targetId);
      if (!(target instanceof HTMLElement)) {
        return;
      }

      const header = document.querySelector(".top");
      const headerHeight = header instanceof HTMLElement ? header.getBoundingClientRect().height : 0;
      const targetTop = window.scrollY + target.getBoundingClientRect().top - headerHeight - 18;

      window.scrollTo({
        top: Math.max(targetTop, 0),
        behavior: "smooth",
      });
      window.history.replaceState(null, "", `#${targetId}`);
    });
  }

  if (input instanceof HTMLInputElement && meta && noResults) {
    const totalParagraphs = paragraphCards.length;

    const applyFilter = () => {
      const rawQuery = input.value.trim();
      const terms = parseSearchTerms(rawQuery);
      let visibleParagraphs = 0;
      const visibleUnitIds = new Set<string>();

      for (const paragraphCard of paragraphCards) {
        if (!(paragraphCard instanceof HTMLElement)) {
          continue;
        }

        const paragraphBody = paragraphCard.querySelector("p:last-child");
        const text = (paragraphBody?.textContent ?? "").toLowerCase();
        const match = terms.length === 0 || terms.every((term) => text.includes(term));
        paragraphCard.hidden = !match;

        if (match) {
          visibleParagraphs += 1;
          const unit = paragraphCard.closest(".unit");
          if (unit instanceof HTMLElement && unit.id) {
            visibleUnitIds.add(unit.id);
          }
        }
      }

      for (const unit of units) {
        if (!(unit instanceof HTMLElement)) {
          continue;
        }
        unit.hidden = !visibleUnitIds.has(unit.id);
      }

      meta.textContent = terms.length > 0
        ? `${visibleParagraphs} of ${totalParagraphs} paragraphs shown`
        : `${totalParagraphs} paragraphs total`;
      noResults.hidden = terms.length === 0 || visibleParagraphs !== 0;
      highlightMatches(rawQuery);
    };

    input.addEventListener("input", applyFilter);
    applyFilter();
  }
</script>

<style>
  .confession-page {
    border: 1px solid var(--confession-accent-border, var(--surface-border));
    border-radius: 14px;
    padding: 0.8rem;
    scroll-margin-top: 7.5rem;
    background: color-mix(in srgb, var(--confession-accent-bg, transparent) 24%, transparent);
  }

  .tools {
    display: grid;
    grid-template-columns: minmax(12rem, 18rem) minmax(14rem, 1fr);
    gap: 0.75rem 1rem;
    align-items: end;
    margin-bottom: 1rem;
    border: 1px solid var(--confession-accent-border, var(--surface-border));
    border-radius: 10px;
    background: var(--confession-accent-bg, var(--surface-bg-muted));
    padding: 0.75rem;
  }

  .tool-control {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }

  .confession-header h1 {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.3rem;
  }

  .confession-header p {
    margin-top: 0;
  }

  .confession-meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  #unit-select,
  input[type="search"] {
    width: 100%;
    box-sizing: border-box;
  }

  .meta {
    grid-column: 1 / -1;
    margin: -0.25rem 0 0;
  }

  #unit-no-results {
    color: var(--color-muted);
    margin-top: 0;
    margin-bottom: 0.8rem;
  }

  .unit {
    margin-bottom: 1.1rem;
    scroll-margin-top: 7.5rem;
  }

  .unit-title {
    color: var(--confession-accent-text, var(--color-heading));
    margin: 0 0 0.55rem;
  }

  .paragraph-list {
    display: grid;
    gap: 0.55rem;
  }

  .unit-back-to-top {
    margin: 0.55rem 0 0;
    text-align: right;
    font-size: 0.9rem;
  }

  .paragraph-card {
    border-color: var(--confession-accent-border, var(--card-border));
    background:
      color-mix(in srgb, var(--confession-accent-bg, transparent) 18%, transparent),
      var(--card-bg);
    scroll-margin-top: 7.5rem;
  }

  .paragraph-card p {
    margin: 0;
  }

  .paragraph-meta {
    color: var(--color-muted);
    font-size: 0.88rem;
    margin-bottom: 0.35rem;
  }

  .paragraph-card p:last-child {
    margin-bottom: 0;
  }

  .confession-page.reader-mode-enabled .paragraph-card p:last-child {
    font-size: 1.06rem;
    line-height: 1.8;
  }

  .paragraph-card mark.search-hit {
    background: #ffdf4d;
    border: 1px solid rgba(99, 69, 10, 0.42);
    border-radius: 0.22rem;
    box-shadow: 0 0 0 1px rgba(255, 248, 184, 0.42);
    color: #1a1300;
    padding: 0 0.14rem;
  }

  :global([data-theme="dark"] .paragraph-card mark.search-hit) {
    background: #ffe66d;
    border-color: rgba(92, 66, 2, 0.82);
    box-shadow: 0 0 0 1px rgba(255, 244, 166, 0.34);
    color: #050505;
  }

  @media (max-width: 720px) {
    .tools {
      grid-template-columns: 1fr;
    }

    .meta {
      grid-column: auto;
    }
  }

  .unit.is-linked-unit {
    border-left: 4px solid rgba(232, 179, 35, 0.58);
    padding-left: 0.55rem;
    border-radius: 8px;
  }

  .paragraph-card.is-linked-paragraph {
    border-color: rgba(232, 179, 35, 0.58);
    box-shadow: 0 0 0 2px rgba(232, 179, 35, 0.2), var(--shadow-card);
  }

  :global(.bible-ref.is-linked-reference) {
    background: rgba(255, 232, 107, 0.72);
    border-radius: 0.35rem;
    padding: 0.02rem 0.2rem;
    border-bottom-style: solid;
    border-bottom-color: rgba(232, 179, 35, 0.82);
  }

  :global([data-theme="dark"] .bible-ref.is-linked-reference) {
    color: #050505 !important;
    background: rgba(255, 233, 117, 0.95) !important;
    border-bottom-color: rgba(92, 66, 2, 0.98) !important;
    font-weight: 800;
    text-shadow: none;
    text-decoration-color: rgba(92, 66, 2, 0.98) !important;
  }

  :global([data-theme="dark"] .bible-ref.is-linked-reference:hover),
  :global([data-theme="dark"] .bible-ref.is-linked-reference:focus-visible) {
    color: #050505 !important;
    background: rgba(255, 233, 117, 0.98) !important;
    border-bottom-color: rgba(92, 66, 2, 0.98) !important;
    text-decoration-color: rgba(92, 66, 2, 0.98) !important;
  }

</style>
