---
import Main from "../layouts/Main.astro";
---

<Main title="Copyright | Confessions Hub">
  <section class="copyright card-panel">
    <h1>Copyright Info</h1>
    <p>
      Confession texts and Bible text included on this site are provided for study, comparison, and citation
      support.
    </p>
    <p>
      Copyright and licensing for those source texts belong to their respective owners and publishers.
    </p>
    <p>
      If you believe any content attribution is incorrect or needs to be updated, please use the
      <a href="https://github.com/abereanone/confessions-hub/issues/new" target="_blank" rel="noopener noreferrer">
        issue form
      </a>
      and include the exact page and text in question.
    </p>
  </section>
</Main>

<style>
  .copyright {
    margin-top: 1rem;
    max-width: 860px;
  }

  .copyright p {
    margin: 0.65rem 0;
  }
</style>
